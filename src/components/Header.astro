---
---

<header class="fixed top-0 w-full flex justify-between items-center px-6 py-4 md:px-10 md:py-6 z-[60] bg-cream-50/80 backdrop-blur-md border-b border-cream-200/60 transition-colors duration-300" id="main-header">
	<a href="/" class="group flex items-center gap-3 transition-transform duration-500 relative z-[70]">
		<span class="relative text-xl md:text-2xl font-semibold tracking-widest text-warm-900 uppercase flex items-center transition-all duration-500 overflow-hidden group-hover:tracking-[0.14em] group-hover:scale-[1.02] whitespace-nowrap">
			<span class="opacity-100 translate-x-0 md:opacity-0 md:-translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 mr-1 text-cream-400 font-light">[</span>
			<span class="logo-shutter-text">Jasper Schut</span>
			<span class="opacity-100 translate-x-0 md:opacity-0 md:translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 ml-1 text-cream-400 font-light">]</span>
		</span>
	</a>

	<!-- Desktop Navigation -->
	<div class="hidden md:flex items-center gap-4 md:gap-8">
		<a href="/series" class="group text-[10px] md:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-warm-900 transition-colors flex items-center relative whitespace-nowrap">
			<span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-cream-400 font-light mr-1">[</span>
			Fotoseries
			<span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-cream-400 font-light ml-1">]</span>
		</a>
		<a href="/over-mij" class="group text-[10px] md:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-warm-900 transition-colors flex items-center relative whitespace-nowrap">
			<span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-cream-400 font-light mr-1">[</span>
			Over mij
			<span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-cream-400 font-light ml-1">]</span>
		</a>
		<a href="https://instagram.com/jas.perspectives" target="_blank" rel="noopener noreferrer" class="group text-[10px] md:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-warm-900 transition-colors flex items-center relative whitespace-nowrap">
			<span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-cream-400 font-light mr-1">[</span>
			<span class="flex items-center gap-2">
				<svg class="ig-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="url(#ig-gradient)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><defs><linearGradient id="ig-gradient" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#f09433"/><stop offset="25%" stop-color="#e6683c"/><stop offset="50%" stop-color="#dc2743"/><stop offset="75%" stop-color="#cc2366"/><stop offset="100%" stop-color="#bc1888"/></linearGradient></defs><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
				<span class="hidden md:inline ig-text">Instagram</span>
			</span>
			<span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-cream-400 font-light ml-1">]</span>
		</a>
	</div>

	<!-- Mobile Hamburger Button -->
	<button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center w-8 h-8 z-[70] relative focus:outline-none group" aria-label="Toggle menu">
		<span class="w-6 h-0.5 bg-warm-900 transition-all duration-300 block absolute top-[11px] group-hover:bg-black" id="hamburger-top"></span>
		<span class="w-6 h-0.5 bg-warm-900 transition-all duration-300 block absolute top-[19px] group-hover:bg-black" id="hamburger-bottom"></span>
	</button>
</header>

<!-- Fullscreen Mobile Navigation Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-cream-50 z-[50] opacity-0 pointer-events-none transition-opacity duration-300 flex flex-col justify-center items-center backdrop-blur-md">
	<nav class="flex flex-col items-center gap-10">
		<a href="/" class="mobile-link group text-2xl uppercase tracking-[0.2em] text-gray-700 hover:text-warm-900 transition-colors relative opacity-0 translate-y-4 font-light">
			Home
		</a>
		<a href="/series" class="mobile-link group text-2xl uppercase tracking-[0.2em] text-gray-700 hover:text-warm-900 transition-colors relative opacity-0 translate-y-4 font-light">
			Fotoseries
		</a>
		<a href="/over-mij" class="mobile-link group text-2xl uppercase tracking-[0.2em] text-gray-700 hover:text-warm-900 transition-colors relative opacity-0 translate-y-4 font-light">
			Over mij
		</a>
		<a href="https://instagram.com/jas.perspectives" target="_blank" rel="noopener noreferrer" class="mobile-link group text-2xl uppercase tracking-[0.2em] text-gray-700 hover:text-warm-900 transition-colors flex items-center gap-3 relative opacity-0 translate-y-4 font-light">
			<svg class="ig-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="url(#ig-gradient-mobile)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><defs><linearGradient id="ig-gradient-mobile" x1="0%" y1="100%" x2="100%" y2="0%"><stop offset="0%" stop-color="#f09433"/><stop offset="25%" stop-color="#e6683c"/><stop offset="50%" stop-color="#dc2743"/><stop offset="75%" stop-color="#cc2366"/><stop offset="100%" stop-color="#bc1888"/></linearGradient></defs><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
			Instagram
		</a>
	</nav>
</div>

<script>
	const menuBtn = document.getElementById('mobile-menu-btn');
	const overlay = document.getElementById('mobile-menu-overlay');
	const header = document.getElementById('main-header');
	const topBar = document.getElementById('hamburger-top');
	const bottomBar = document.getElementById('hamburger-bottom');
	const mobileLinks = document.querySelectorAll('.mobile-link');
	
	let isMenuOpen = false;

	if (menuBtn && overlay && topBar && bottomBar && header) {
		menuBtn.addEventListener('click', () => {
			isMenuOpen = !isMenuOpen;
			
			if (isMenuOpen) {
				// Open Menu
				overlay.classList.remove('opacity-0', 'pointer-events-none');
				overlay.classList.add('opacity-100', 'pointer-events-auto');
				
				// Optional: make header transparent or white to blend with menu
				header.classList.remove('bg-cream-50/80', 'backdrop-blur-md', 'border-b', 'border-cream-200/60');
				
				// Transform Hamburger to X
				topBar.style.transform = 'translateY(4px) rotate(45deg)';
				bottomBar.style.transform = 'translateY(-4px) rotate(-45deg)';
				
				// Prevent background scrolling
				document.body.style.overflow = 'hidden';

				// Staggered fade in for links
				mobileLinks.forEach((link, index) => {
					setTimeout(() => {
						link.classList.remove('opacity-0', 'translate-y-4');
						link.classList.add('opacity-100', 'translate-y-0', 'transition-all', 'duration-500');
					}, 100 + (index * 100)); // 100ms stagger
				});
				
			} else {
				// Close Menu
				overlay.classList.add('opacity-0', 'pointer-events-none');
				overlay.classList.remove('opacity-100', 'pointer-events-auto');
				
				header.classList.add('bg-cream-50/80', 'backdrop-blur-md', 'border-b', 'border-cream-200/60');

				// Transform X to Hamburger
				topBar.style.transform = 'translateY(0) rotate(0)';
				bottomBar.style.transform = 'translateY(0) rotate(0)';
				
				document.body.style.overflow = '';
				
				// Reset links
				mobileLinks.forEach((link) => {
					link.classList.add('opacity-0', 'translate-y-4');
					link.classList.remove('opacity-100', 'translate-y-0');
				});
			}
		});
	}
</script>
