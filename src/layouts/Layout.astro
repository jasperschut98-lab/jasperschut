---
import '../styles/global.css';
import CoffeeButton from '../components/CoffeeButton.astro';

interface Props {
	title: string;
	description?: string;
}

const { 
  title, 
  	description = "Jasper Schut — Straatfotograaf. Ontdek een minimalistische collectie van analoge en digitale straatfotografie, vastgelegd met een scherp oog voor het alledaagse." 
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Jasper Schut",
  "jobTitle": "Street Photographer",
  "url": "https://jasperschut.nl",
  "sameAs": [
    "https://instagram.com/jas.perspectives"
  ],
  "description": description
};
---

<!doctype html>
<html lang="nl" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Jasper Schut" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=4" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico?v=4" />
		<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png?v=4" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=4" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png?v=4" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- OpenGraph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://jasperschut.nl/" />
		<meta property="og:image" content="/images/logo.png" />
		<meta property="og:site_name" content="Jasper Schut | Fotografie" />

		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Switched to Outfit for a sharper, modern, premium aesthetic -->
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;600&display=swap" rel="stylesheet">
	</head>
	<body class="bg-cream-50 text-gray-900 font-sans antialiased selection:bg-gray-900 selection:text-cream-50">
		<slot />

		<!-- Sticky Navigation Buttons (Global) -->
		<div class="fixed bottom-4 left-4 sm:bottom-6 sm:left-6 z-40 flex flex-col gap-3">
			<button id="back-to-top" class="opacity-0 translate-y-4 pointer-events-none transition-all duration-500 bg-cream-50 border border-cream-300 shadow-sm hover:shadow-md hover:border-warm-900 text-warm-900 w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center rounded-full cursor-pointer" aria-label="Terug naar boven">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
			</button>
			<CoffeeButton />
		</div>
		
		<!-- Global Image Protection Script -->
		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const images = document.querySelectorAll('img');
				images.forEach(img => {
					// Prevent right-click "Save Image As..."
					img.addEventListener('contextmenu', (e) => e.preventDefault());
					// Prevent drag-to-desktop
					img.addEventListener('dragstart', (e) => e.preventDefault());
				});
				
				// Optional fallback: global listener just in case new images are added dynamically (e.g. infinite scroll)
				document.addEventListener('contextmenu', (e) => {
					if ((e.target as HTMLElement)?.tagName === 'IMG') {
						e.preventDefault();
					}
				});
				document.addEventListener('dragstart', (e) => {
					if ((e.target as HTMLElement)?.tagName === 'IMG') {
						e.preventDefault();
					}
				});

				// Back to Top Button Logic
				const backToTopBtn = document.getElementById('back-to-top');
				
				window.addEventListener('scroll', () => {
					if (window.scrollY > 500) {
						backToTopBtn?.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
						backToTopBtn?.classList.add('opacity-100', 'translate-y-0');
					} else {
						backToTopBtn?.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
						backToTopBtn?.classList.remove('opacity-100', 'translate-y-0');
					}
				});

				backToTopBtn?.addEventListener('click', () => {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			});
		</script>
	</body>
</html>
