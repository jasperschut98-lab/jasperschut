---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Over Mij | Jasper Schut Fotografie" description="Jasper Schut is een straatfotograaf gevestigd in Zoetermeer.">
	<!-- Fixed Header/Nav -->
	<header class="fixed top-0 w-full flex justify-between items-center px-6 py-4 sm:px-10 sm:py-6 z-40 bg-white/80 backdrop-blur-md border-b border-gray-100">
		<a href="/" class="group flex items-center gap-3 transition-transform duration-500">
			<span class="relative text-xl sm:text-2xl font-semibold tracking-widest text-gray-900 uppercase flex items-center transition-all duration-500 overflow-hidden group-hover:tracking-[0.2em]">
				<span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 mr-1 text-gray-400 font-light">[</span>
				<span class="logo-shutter-text">Jasper Schut</span>
				<span class="opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 ml-1 text-gray-400 font-light">]</span>
			</span>
		</a>
		<div class="flex items-center gap-4 sm:gap-6">
			<a href="/series" class="text-[10px] sm:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-gray-900 transition-colors">Series</a>
			<!-- Active state on Over mij link -->
			<a href="/over-mij" class="text-[10px] sm:text-xs uppercase tracking-[0.2em] text-gray-900 border-b border-gray-900 transition-colors">Over mij</a>
			<a href="https://instagram.com/jas.perspectives" target="_blank" rel="noopener noreferrer" class="text-[10px] sm:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-gray-900 transition-colors flex items-center gap-2">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
				<span class="hidden sm:inline">Instagram</span>
			</a>
		</div>
	</header>

	<main class="w-full pt-32 pb-24 px-6 sm:px-10 max-w-7xl mx-auto min-h-screen">
		
		<!-- 2-Column Layout -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 w-full">
			
			<!-- Left Column: Portrait -->
			<div class="w-full animate-fade-in-slow">
				<div class="aspect-[3/4] overflow-hidden bg-gray-100 rounded-sm relative group">
					<!-- Replace with the precise portrait from the scraper if favored, or use one of the existing ones -->
					<img 
						src="/images/IMG_0143-768x1024.jpeg" 
						alt="Portret Jasper Schut" 
						class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105"
					/>
				</div>
			</div>

			<!-- Right Column: Text & Contact -->
			<div class="w-full flex flex-col justify-center max-w-xl animate-fade-in-delayed">
				
				<p class="text-lg text-gray-600 font-light leading-relaxed mb-4">
					Jasper Schut is een straatfotograaf gevestigd in Zoetermeer.
				</p>
				<p class="text-base sm:text-lg text-gray-600 font-light leading-relaxed mb-4">
					Met een scherp oog voor compositie en timing legt hij het alledaagse vast op een manier die verder kijkt dan het oppervlak. Zijn werk kenmerkt zich door een directe, ongeposeerde stijl — gedreven door nieuwsgierigheid naar de mens en de stad.
				</p>
				<p class="text-base sm:text-lg text-gray-600 font-light leading-relaxed mb-12">
					Jasper is beschikbaar voor opdrachten, samenwerkingen en publicaties. Neem gerust contact op via onderstaand formulier.
				</p>

				<!-- Contact Form Wrapper for Distinct Contrast -->
				<div class="bg-gray-50 border border-gray-100 p-8 sm:p-10 rounded-sm shadow-sm relative overflow-hidden">
					<div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-30 pointer-events-none"></div>

					<h2 class="text-sm uppercase tracking-widest text-gray-900 mb-6 font-medium relative z-10">Neem contact op</h2>
					
					<form class="flex flex-col gap-6 relative z-10" action="mailto:contact@jasperschut.nl" method="POST" enctype="text/plain">
						<div class="flex flex-col gap-1">
							<label for="name" class="text-xs text-gray-500 uppercase tracking-wider">Naam</label>
							<input type="text" id="name" name="name" required class="w-full border-b border-gray-300 bg-transparent py-2 focus:outline-none focus:border-gray-900 transition-colors text-gray-900 font-light" placeholder="Jouw naam" />
						</div>
						<div class="flex flex-col gap-1">
							<label for="email" class="text-xs text-gray-500 uppercase tracking-wider">E-mail</label>
							<input type="email" id="email" name="email" required class="w-full border-b border-gray-300 bg-transparent py-2 focus:outline-none focus:border-gray-900 transition-colors text-gray-900 font-light" placeholder="jouw@email.nl" />
						</div>
						<div class="flex flex-col gap-1">
							<label for="message" class="text-xs text-gray-500 uppercase tracking-wider">Bericht</label>
							<textarea id="message" name="message" rows="4" required class="w-full border-b border-gray-300 bg-transparent py-2 focus:outline-none focus:border-gray-900 transition-colors text-gray-900 font-light resize-none" placeholder="Wat kan ik voor je doen?"></textarea>
						</div>
						<button type="submit" class="mt-4 px-8 py-4 border border-gray-300 hover:border-gray-900 bg-white hover:bg-gray-900 hover:text-white transition-all duration-300 text-xs uppercase tracking-widest text-gray-700 w-fit cursor-pointer shadow-sm">
							Verstuur
						</button>
					</form>
				</div>
			</div>

		</div>
	</main>

	<!-- Minimal Footer just for this page -->
	<footer class="w-full flex justify-between px-6 py-8 border-t border-gray-100 bg-white mt-auto">
		<p class="text-xs text-gray-400 tracking-wider font-light">
			&copy; {new Date().getFullYear()} Jasper Schut. Fotografie.
		</p>
	</footer>

</Layout>

<style>
	/* Entrance animations */
	@keyframes fadeInSlow {
		from { opacity: 0; transform: translateY(20px); filter: blur(5px); }
		to { opacity: 1; transform: translateY(0); filter: blur(0); }
	}
	.animate-fade-in-slow {
		animation: fadeInSlow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
	.animate-fade-in-delayed {
		opacity: 0;
		animation: fadeInSlow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		animation-delay: 0.3s;
	}
</style>
