---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Over Mij | Jasper Schut Fotografie" description="Jasper Schut is een straatfotograaf gevestigd in Zoetermeer.">
	<!-- Fixed Header/Nav -->
	<header class="fixed top-0 w-full flex justify-between items-center px-6 py-4 sm:px-10 sm:py-6 z-40 bg-white/80 backdrop-blur-md border-b border-gray-100">
		<a href="/" class="group flex items-center gap-3 transition-transform duration-500">
			<span class="relative text-xl sm:text-2xl font-semibold tracking-widest text-gray-900 uppercase flex items-center transition-all duration-500 overflow-hidden group-hover:tracking-[0.2em]">
				<span class="opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 mr-1 text-gray-400 font-light">[</span>
				<span class="logo-shutter-text">Jasper Schut</span>
				<span class="opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 ml-1 text-gray-400 font-light">]</span>
			</span>
		</a>
		<div class="flex items-center gap-4 sm:gap-8">
			<a href="/series" class="group text-[10px] sm:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-gray-900 transition-colors flex items-center relative">
				<span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-gray-400 font-light mr-1">[</span>
				Series
				<span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-gray-400 font-light ml-1">]</span>
			</a>
			<!-- Active state on Over mij link -->
			<a href="/over-mij" class="group text-[10px] sm:text-xs uppercase tracking-[0.2em] text-gray-900 border-b border-gray-900 transition-colors flex items-center relative">
				<span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-gray-400 font-light mr-1">[</span>
				Over mij
				<span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-gray-400 font-light ml-1">]</span>
			</a>
			<a href="https://instagram.com/jas.perspectives" target="_blank" rel="noopener noreferrer" class="group text-[10px] sm:text-xs uppercase tracking-[0.2em] text-gray-500 hover:text-gray-900 transition-colors flex items-center gap-2 relative">
				<span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-gray-400 font-light mr-1">[</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
				<span class="hidden sm:inline">Instagram</span>
				<span class="opacity-0 translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-gray-400 font-light ml-1">]</span>
			</a>
		</div>
	</header>

	<main class="w-full pt-32 pb-24 px-6 sm:px-10 max-w-7xl mx-auto min-h-screen">
		
		<!-- Top Section: 30/70 Layout -->
		<div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16 w-full mb-20 lg:mb-32 items-center">
			
			<!-- Left Column: Portrait (30%) -->
			<div class="md:col-span-4 w-full animate-fade-in-slow">
				<div class="aspect-[3/4] overflow-hidden bg-gray-100 rounded-sm relative group">
					<img 
						src="/images/imm007_9.jpg" 
						alt="Portret Jasper Schut" 
						class="w-full h-full object-cover object-[center_30%] sm:object-center transition-transform duration-1000 hover:scale-105"
					/>
				</div>
			</div>

			<!-- Right Column: Intro Text & Gear (70%) -->
			<div class="md:col-span-8 w-full h-full flex flex-col justify-between animate-fade-in-delayed">
				
				<!-- Top: Intro Text -->
				<div>
					<p class="text-lg text-gray-600 font-light leading-relaxed mb-4">
						Jasper Schut is een straatfotograaf gevestigd in Zoetermeer.
					</p>
					<p class="text-base sm:text-lg text-gray-600 font-light leading-relaxed mb-4">
						Met een scherp oog voor compositie en timing legt hij het alledaagse vast op een manier die verder kijkt dan het oppervlak. Zijn werk kenmerkt zich door een directe, ongeposeerde stijl — gedreven door nieuwsgierigheid naar de mens en de stad.
					</p>
					<p class="text-base sm:text-lg text-gray-600 font-light leading-relaxed">
						Jasper is beschikbaar voor opdrachten, samenwerkingen en publicaties.
					</p>
				</div>

				<!-- Bottom: Gear Section -->
				<div class="border-t border-gray-100 pt-6 mt-8 xl:mt-0">
					<h2 class="text-sm uppercase tracking-widest text-gray-900 mb-6 font-medium">Materialen / Gear</h2>
					<ul class="space-y-4">
						<li class="flex flex-col xl:flex-row xl:justify-between xl:items-baseline border-b border-gray-50 pb-2 text-sm xl:text-base">
							<span class="text-xs text-gray-400 uppercase tracking-widest mb-1 xl:mb-0">Digitale Camera</span>
							<span class="text-gray-900 font-light">Sony CyberShot RX100 VII</span>
						</li>
						<li class="flex flex-col xl:flex-row xl:justify-between xl:items-baseline border-b border-gray-50 pb-2 text-sm xl:text-base">
							<span class="text-xs text-gray-400 uppercase tracking-widest mb-1 xl:mb-0">Analoge Camera</span>
							<span class="text-gray-900 font-light">Canon AE-1 Program</span>
						</li>
						<li class="flex flex-col xl:flex-row xl:justify-between xl:items-baseline border-b border-gray-50 pb-2 text-sm xl:text-base">
							<span class="text-xs text-gray-400 uppercase tracking-widest mb-1 xl:mb-0">Accessoires</span>
							<span class="text-gray-900 font-light">Peak Design Slide Lite, SanDisk Extreme Pro</span>
						</li>
					</ul>
				</div>

			</div>
		</div>

		<!-- Single Column Layout for Contact -->
		<div class="max-w-4xl mx-auto w-full animate-fade-in-delayed">

			<!-- Contact Form Wrapper -->
			<div class="bg-gray-50 border border-gray-100 p-8 sm:p-12 rounded-sm shadow-sm relative overflow-hidden">
				<div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-30 pointer-events-none"></div>

				<h2 class="text-sm uppercase tracking-widest text-gray-900 mb-8 font-medium relative z-10">Neem contact op</h2>
				
				<form id="contact-form" class="flex flex-col gap-6 relative z-10" action="https://formsubmit.co/contact@jasperschut.nl" method="POST">
					<!-- FormSubmit.co config -->
					<input type="hidden" name="_subject" value="Nieuw bericht via jasperschut.nl">
					<input type="text" name="_honey" style="display:none">
					<input type="hidden" name="_autoresponse" value="Bedankt voor je bericht! Ik neem zo snel mogelijk contact met je op. Groet, Jasper Schut">

					<div class="flex flex-col gap-1">
						<label for="name" class="text-xs text-gray-500 uppercase tracking-wider">Naam <span class="text-red-500">*</span></label>
						<input type="text" id="name" name="name" required class="w-full border-b border-gray-300 bg-transparent py-2 focus:outline-none focus:border-gray-900 transition-colors text-gray-900 font-light" placeholder="Jouw naam" />
					</div>
					<div class="flex flex-col gap-1">
						<label for="email" class="text-xs text-gray-500 uppercase tracking-wider">E-mail <span class="text-red-500">*</span></label>
						<input type="email" id="email" name="email" required class="w-full border-b border-gray-300 bg-transparent py-2 focus:outline-none focus:border-gray-900 transition-colors text-gray-900 font-light" placeholder="jouw@email.nl" />
					</div>
					<div class="flex flex-col gap-1">
						<label for="message" class="text-xs text-gray-500 uppercase tracking-wider">Bericht <span class="text-red-500">*</span></label>
						<textarea id="message" name="message" rows="4" required class="w-full border-b border-gray-300 bg-transparent py-2 focus:outline-none focus:border-gray-900 transition-colors text-gray-900 font-light resize-none" placeholder="Wat kan ik voor je doen?"></textarea>
					</div>
					<button id="submit-btn" type="submit" class="mt-4 px-8 py-4 border border-gray-300 hover:border-gray-900 bg-white hover:bg-gray-900 hover:text-white transition-all duration-300 text-xs uppercase tracking-widest text-gray-700 w-fit cursor-pointer shadow-sm">
						Verstuur
					</button>
				</form>

				<!-- Success Popup (Toast) -->
				<div id="form-popup" class="fixed bottom-10 right-10 md:bottom-12 md:right-12 z-50 bg-gray-900 text-white px-6 py-4 rounded-sm shadow-xl flex items-center gap-3 opacity-0 translate-y-4 pointer-events-none transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
					</svg>
					<span class="text-sm tracking-wider font-light">Bericht verstuurd!</span>
				</div>
			</div>
		</div>
	</main>

	<!-- Minimal Footer just for this page -->
	<footer class="w-full flex justify-center items-center gap-3 px-6 py-8 border-t border-gray-100 bg-white mt-auto">
		<p class="text-xs text-gray-400 tracking-wider font-light m-0">
			&copy; {new Date().getFullYear()} Jasper Schut. Fotografie.
		</p>
		<span class="text-xs text-gray-200 font-light translate-y-[-1px]">|</span>
		<a href="/privacy" class="text-xs text-gray-400 hover:text-gray-900 tracking-wider font-light transition-colors m-0">
			Privacy Policy
		</a>
	</footer>

</Layout>

<style>
	/* Entrance animations */
	@keyframes fadeInSlow {
		from { opacity: 0; transform: translateY(20px); filter: blur(5px); }
		to { opacity: 1; transform: translateY(0); filter: blur(0); }
	}
	.animate-fade-in-slow {
		animation: fadeInSlow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
	.animate-fade-in-delayed {
		opacity: 0;
		animation: fadeInSlow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		animation-delay: 0.3s;
	}
</style>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement;
	const successPopup = document.getElementById('form-popup');
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

	if (form) {
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			
			if (submitBtn) {
				submitBtn.disabled = true;
				submitBtn.innerText = 'Verzenden...';
			}

			const formData = new FormData(form);
			const xhr = new XMLHttpRequest();
			xhr.open("POST", "https://formsubmit.co/ajax/contact@jasperschut.nl", true);
			xhr.setRequestHeader("Accept", "application/json");
			
			xhr.onreadystatechange = function() {
				if (xhr.readyState !== XMLHttpRequest.DONE) return;
				
				if (xhr.status === 200) {
					// Clear the form
					form.reset();
					
					// Show popup fast
					if (successPopup) {
						successPopup.classList.remove('opacity-0', 'translate-y-4');
						successPopup.classList.add('opacity-100', 'translate-y-0');

						// Fade out quickly after 3 seconds
						setTimeout(() => {
							successPopup.classList.remove('opacity-100', 'translate-y-0');
							successPopup.classList.add('opacity-0', 'translate-y-4');
						}, 3000);
					}
				} else {
					console.error("Fout bij verzenden formulier", xhr.status, xhr.statusText);
				}
				
				// Reset button
				if (submitBtn) {
					submitBtn.disabled = false;
					submitBtn.innerText = 'Verstuur';
				}
			};
			
			xhr.send(formData);
		});
	}
</script>
