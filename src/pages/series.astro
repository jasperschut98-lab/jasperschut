---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const series = [
	{ title: 'Maastricht', image: '/images/019-1024x683.jpg', count: 24 },
	{ title: 'Straatfotografie', image: '/images/imm028_N28-1024x683.jpg', count: 41 },
	{ title: 'Zwart-Wit', image: '/images/IMG_0143-768x1024.jpeg', count: 18 },
	{ title: 'Portret', image: '/images/IMG_4346-1024x768.jpeg', count: 12 }
];
---

<Layout title="Fotoseries | Jasper Schut Fotografie" description="Bekijk de fotoseries en mappen van Jasper Schut.">
	<!-- Reusable Header Component -->
	<Header />

	<main class="w-full pt-32 pb-24 px-4 sm:px-6 md:px-8 max-w-[1600px] mx-auto min-h-screen">
		
		<div class="mb-16 animate-fade-in-slow text-center">
			<h1 class="text-3xl sm:text-5xl font-light mb-4 text-gray-900">Fotoseries</h1>
			<p class="text-gray-500 font-light max-w-xl mx-auto">Verken verschillende collecties en projecten.</p>
		</div>

		<!-- Folders / Series Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-[1200px] mx-auto">
			{series.map((item, index) => (
				<a href="#" class="group block relative overflow-hidden bg-gray-100 aspect-[4/3] animate-fade-in-delayed shadow-sm hover:shadow-lg transition-all duration-500 rounded-sm" style={`animation-delay: ${index * 150}ms`}>
					<!-- Folder Cover Image -->
					<img 
						src={item.image} 
						alt={`${item.title} directory`} 
						class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
					/>
					
					<!-- Dark overlay on hover -->
					<div class="absolute inset-0 bg-black/10 group-hover:bg-black/40 transition-colors duration-500"></div>

					<!-- Folder Info (Title & Count) -->
					<div class="absolute inset-0 p-6 flex flex-col justify-end opacity-90 group-hover:opacity-100 transition-opacity">
						<div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
							<h2 class="text-white text-2xl font-light tracking-wide drop-shadow-md mb-1">{item.title}</h2>
							<p class="text-white/80 text-xs tracking-[0.2em] uppercase font-medium">{item.count} Foto's</p>
						</div>
					</div>
					
					<!-- UI Folder Icon indicator -->
					<div class="absolute top-4 right-4 bg-white/20 backdrop-blur-md p-2 rounded-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg>
					</div>
				</a>
			))}
		</div>

	</main>

	<!-- Footer -->
	<footer class="w-full flex justify-center items-center gap-3 px-6 py-8 border-t border-gray-100 bg-white mt-auto">
		<p class="text-xs text-gray-400 tracking-wider font-light m-0">
			&copy; {new Date().getFullYear()} Jasper Schut. Fotografie.
		</p>
		<span class="text-xs text-gray-200 font-light translate-y-[-1px]">|</span>
		<a href="/privacy" class="text-xs text-gray-400 hover:text-gray-900 tracking-wider font-light transition-colors m-0">
			Privacy Policy
		</a>
	</footer>

</Layout>

<style>
	/* Entrance animations */
	@keyframes fadeInSlow {
		from { opacity: 0; transform: translateY(20px); filter: blur(5px); }
		to { opacity: 1; transform: translateY(0); filter: blur(0); }
	}
	.animate-fade-in-slow {
		animation: fadeInSlow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
	.animate-fade-in-delayed {
		opacity: 0;
		animation: fadeInSlow 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
		animation-fill-mode: forwards;
	}
</style>
